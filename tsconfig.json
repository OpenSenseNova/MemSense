{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": false,
    "resolveJsonModule": true,
    "allowJs": true,
    "types": ["node"],
    "paths": {
      "openclaw/plugin-sdk": ["/opt/homebrew/lib/node_modules/openclaw/dist/plugin-sdk/index.d.ts"]
    }
  },
  "include": ["index.ts", "src/**/*.js"],
  "exclude": ["node_modules", "dist", "test"]
}
