# Memsense environment example

# Core
MEMSENSE_DATABASE_URL=postgresql://memsense:memsense@postgres:5432/memsense
MEMSENSE_PORT=8787

# Dashboard RBAC
MEMSENSE_DASHBOARD_TOKENS_JSON={"demo":"admin"}

# Embedding provider mode: openai | bge_http
MEMSENSE_EMBEDDING_PROVIDER=bge_http

# OpenAI-compatible config (used when provider=openai)
MEMSENSE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEMSENSE_OPENAI_API_KEY=
MEMSENSE_EMBEDDING_MODEL=text-embedding-v4

# Local BGE config (used when provider=bge_http)
MEMSENSE_BGE_ENDPOINT=http://bge:8080/embed
MEMSENSE_BGE_MODEL=BAAI/bge-large-zh-v1.5
