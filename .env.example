# Memsense environment example

# Core
# Docker mode example:
#   postgresql://memsense:memsense@postgres:5432/memsense
# No-docker local example:
#   postgresql://127.0.0.1:5432/memsense
MEMSENSE_DATABASE_URL=postgresql://127.0.0.1:5432/memsense
MEMSENSE_PORT=8787
# URL used by the OpenClaw plugin to call the Memsense HTTP API.
# Docker mode should use the host port, e.g. http://127.0.0.1:18795
MEMSENSE_API_URL=http://127.0.0.1:8787
MEMSENSE_TENANT_ID=default
MEMSENSE_SCOPE=user

# Dashboard RBAC
MEMSENSE_DASHBOARD_TOKENS_JSON={"demo":"admin"}

# Embedding provider mode: openai | bge_http
MEMSENSE_EMBEDDING_PROVIDER=bge_http

# OpenAI-compatible config (used when provider=openai)
MEMSENSE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEMSENSE_OPENAI_API_KEY=
MEMSENSE_EMBEDDING_MODEL=text-embedding-v4

# Local BGE config (used when provider=bge_http)
# Docker mode example:
#   http://bge:8080/embed
# No-docker local example:
#   http://127.0.0.1:8080/embed
MEMSENSE_BGE_PORT=8080
MEMSENSE_BGE_ENDPOINT=http://127.0.0.1:8080/embed
MEMSENSE_BGE_MODEL=BAAI/bge-large-zh-v1.5

# Optional tagger LLM
# Default auto mode reuses the model/auth already configured in OpenClaw when
# the OpenClaw CLI is available. If OpenClaw is unavailable, tagging is skipped.
# Docker mode usually cannot access the host OpenClaw CLI; use openai-compatible
# tagger settings below or run tag-worker on the host if you need Docker tagging.
MEMSENSE_TAGGER_PROVIDER=auto
MEMSENSE_TAGGER_MODEL=auto
MEMSENSE_TAG_WORKER_CONCURRENCY=3
MEMSENSE_OPENCLAW_CLI=openclaw
MEMSENSE_OPENCLAW_TAGGER_TIMEOUT_MS=90000

# OpenAI-compatible tagger mode:
#   MEMSENSE_TAGGER_PROVIDER=openai
MEMSENSE_TAGGER_BASE_URL=
MEMSENSE_TAGGER_API_KEY=
